pipeline {
    agent any

    triggers {
        pollSCM('H/5 * * * *')
    }

    stages {
        stage('Checkout') {
            steps {
                // watch feature branch!
                git branch: 'feature',
                    credentialsId: 'githubcreds',
                    url: 'https://github.com/hinalnayak2003-pixel/project.git'
            }
        }

        stage('Pull Latest') {
            steps {
                sh 'git fetch --all'
                sh 'git pull origin feature'
            }
        }

        stage('Check Changes') {
            steps {
                sh 'git log --oneline -5'
                sh '''
                    if [ $(git rev-list --count HEAD) -gt 1 ]; then
                        echo "=== Changes from last commit ==="
                        git diff HEAD~1 HEAD
                    else
                        echo "First commit - nothing to compare!"
                    fi
                '''
            }
        }

        stage('Build') {
            steps {
                echo "Building..."
                sh 'mvn clean install'
            }
        }

        stage('Auto Merge') {
            steps {
                sh '''
                    git config user.email "jenkins@jenkins.com"
                    git config user.name "Jenkins"
                    git checkout main
                    git pull origin main
                    git merge origin/feature
                    git push https://hinalnayak2003-pixel:YOUR-TOKEN@github.com/hinalnayak2003-pixel/project.git main
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Auto Merge Done!"
        }
        failure {
            echo "❌ Merge Failed!"
        }
    }
}
